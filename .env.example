# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Mfinity

# ─── Database (PostgreSQL via Supabase) ────────────────────────────────────────
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# ─── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── Auth / JWT ────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_64_chars_use_openssl_rand_base64_64
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECRET=your_cookie_signing_secret_min_32_chars

# ─── Redis (Upstash) ───────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://[ENDPOINT].upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# ─── Resend (Email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@mfinity.trade
RESEND_FROM_NAME=Mfinity

# ─── Paystack ──────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret_key
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public_key

# Paystack Plan Codes (create plans on dashboard.paystack.com → Products → Plans)
PAYSTACK_PRO_MONTHLY_PLAN_CODE=PLN_your_pro_monthly_code
PAYSTACK_PRO_YEARLY_PLAN_CODE=PLN_your_pro_yearly_code
PAYSTACK_ENTERPRISE_MONTHLY_PLAN_CODE=PLN_your_enterprise_monthly_code
PAYSTACK_ENTERPRISE_YEARLY_PLAN_CODE=PLN_your_enterprise_yearly_code

# ─── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name

# ─── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@mfinity.trade
ADMIN_SECRET=your_admin_bootstrap_secret
